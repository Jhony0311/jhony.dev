---
import Layout from '../../layouts/Layout.astro';
import { GardenPage } from '../../components/garden/GardenPage';

export function getStaticPaths() {
    const categories = ['essay', 'note', 'snippet'];
    return categories.map((category) => ({
        params: { category },
    }));
}

const categoryParam = Astro.params.category ?? '';
const initialSelectedType =
    categoryParam === 'essay'
        ? 'Essay'
        : categoryParam === 'note'
          ? 'Note'
          : categoryParam === 'snippet'
            ? 'Snippet'
            : 'All';
const search = Astro.url.searchParams;
const stageParam = search.get('stage');
const initialSelectedStage =
    stageParam === 'Seedling' ||
    stageParam === 'Budding' ||
    stageParam === 'Evergreen'
        ? stageParam
        : 'All';
const initialSelectedTags = (search.get('tags') ?? '')
    .split(',')
    .map((tag) => tag.trim())
    .filter(Boolean);
const initialPage = Math.max(1, Number(search.get('page') ?? 1) || 1);
---

<Layout
    title={`${initialSelectedType} · Garden · Jonathan Ortega`}
    description="A living digital garden of essays, notes, and snippets with maturity stages and evolving ideas."
>
    <GardenPage
        client:load
        initialSelectedType={initialSelectedType}
        initialSelectedStage={initialSelectedStage}
        initialSelectedTags={initialSelectedTags}
        initialPage={initialPage}
    />
</Layout>
